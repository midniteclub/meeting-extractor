# API key for the LLM used to generate summaries (optional but recommended)
# For Claude: get one at https://console.anthropic.com
# For a compatible third-party API (e.g. Qwen via a proxy): use that key here
ANTHROPIC_API_KEY=your_api_key_here

# Custom base URL — only needed when using a third-party Anthropic-compatible
# endpoint. Leave blank when using the real Anthropic API.
# Example (Alibaba DashScope): https://dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic

# Model name passed to the API.
# Real Anthropic default: claude-sonnet-4-6
# DashScope / Qwen example: qwen3.5-plus
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3.5-plus

# HuggingFace token — used for speaker diarization (optional)
# 1. Create a free account at https://huggingface.co
# 2. Accept the terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=your_token_here

# Whisper model size: tiny | base | small | medium | large
# Larger = more accurate but slower and needs more RAM
# Recommendation: base (fast) or small (better accuracy)
WHISPER_MODEL=base

# Set to false to disable optional features
RECORD_VIDEO=true
